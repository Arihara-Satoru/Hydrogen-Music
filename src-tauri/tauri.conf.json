{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Hydrogen Music",
  "version": "0.5.9",
  "identifier": "com.hydrogenmusic.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hydrogen Music",
        "label": "main",
        "width": 1024,
        "height": 672,
        "minWidth": 1024,
        "minHeight": 672,
        "center": true,
        "decorations": true,
        "focus": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: http:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' https: http:; media-src 'self' https: http:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBNEUyMTM2MUU2ODNFMwpSV1RqZytaaEUrS2tBejh2bzg2RTI2V2VMczNpQTRjbk9acmIxcDQyVk9wNVJoOC9aN2N2R3VUbAo=",
      "endpoints": [
        "https://github.com/Arihara-Satoru/Hydrogen-Music/releases/latest/download/update.json",
        "https://github.com/Arihara-Satoru/Hydrogen-Music/releases/download/v0.5.9/update.json"
      ],
      "dialog": false
    }
  }
}
